# ── PostgreSQL (Railway Plugin) ───────────────────────────────────────────────
# Railway auto-injects DATABASE_URL when you add the Postgres plugin.
# These individual vars are used by postgres_client.py — set them to match.
POSTGRES_HOST=${{Postgres.PGHOST}}
POSTGRES_PORT=${{Postgres.PGPORT}}
POSTGRES_DB=${{Postgres.PGDATABASE}}
POSTGRES_USER=${{Postgres.PGUSER}}
POSTGRES_PASSWORD=${{Postgres.PGPASSWORD}}

# ── Redis (Railway Plugin) ────────────────────────────────────────────────────
# Railway auto-injects REDIS_URL when you add the Redis plugin.
REDIS_HOST=${{Redis.REDISHOST}}
REDIS_PORT=${{Redis.REDISPORT}}

# ── Neo4j (Railway Template or External) ──────────────────────────────────────
# Deploy Neo4j as a separate Railway service or use AuraDB (free tier).
NEO4J_URI=bolt://your-neo4j-service.railway.internal:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_strong_password

# ── ChromaDB (Railway Service) ────────────────────────────────────────────────
# Deploy ChromaDB as a separate Railway service.
CHROMADB_HOST=your-chromadb-service.railway.internal
CHROMADB_PORT=8000

# ── External APIs ─────────────────────────────────────────────────────────────
HUNTER_API_KEY=
SERPAPI_KEY=
OPENCORPORATES_TOKEN=
PACER_USERNAME=
PACER_PASSWORD=

# ── Ollama (optional — skip if not using LLM locally) ─────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
