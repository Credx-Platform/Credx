# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Database ──────────────────────────────────────────────────────────────────
# Defaults to ./data/credx.db — override for a custom path
# DB_PATH=/var/data/credx.db

# ── Encryption (REQUIRED for production) ─────────────────────────────────────
# 32 bytes as 64 hex characters. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_char_hex_key_here

# ── SMTP (Transactional Email) ────────────────────────────────────────────────
# If not set, emails are logged to console only (preview mode)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key_here

# ── Email identity ────────────────────────────────────────────────────────────
EMAIL_FROM="CredX <noreply@credx.com>"
SUPPORT_EMAIL=support@credx.com

# ── Business identity ─────────────────────────────────────────────────────────
BUSINESS_NAME="The Malloy Group Financial LLC"

# ── App URL (used in email CTAs) ──────────────────────────────────────────────
APP_URL=https://onboarding.credx.com

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your domain in production; leave unset to block cross-origin requests
# CORS_ORIGIN=https://credx.com
